#!/usr/bin/bash

PAPER_API="https://fill.papermc.io/v3/projects/paper"
USER_AGENT="papermc-utils (https://github.com/StripesAndPlaid/papermc-utils)"
SERVER_JAR="/home/minecraft/server/paper.jar"
VERSION_FILE="/home/minecraft/server/version_history.json"

usage() {
  echo "Usage: $(basename "$0") [-a|-b] [version]"
  echo
  echo "Options:"
  echo "  -a       Select ALPHA channel builds"
  echo "  -b       Select BETA channel builds"
  echo "  version  PaperMC version"
  exit 1
}

select_channel() {
  if [[ "$channel" != "STABLE" ]]; then
    echo "Error: Select only 1 build channel" && usage
  fi

  channel="$1"
}

get_builds() {
  curl -s -H "User-Agent: $USER_AGENT" "${PAPER_API}/versions/${1}/builds"
}

get_build() {
  echo "$1" | jq -r --arg channel "$channel" 'first(.[] | select(.channel == $channel) | .id) // "null"'
}

get_download_url() {
  echo "$1" | jq -r --arg channel "$channel" 'first(.[] | select(.channel == $channel) | .downloads."server:default".url) // "null"'
}

# Parse flags
channel="STABLE"
while getopts ":ab" opt; do
  case $opt in
    a) select_channel "ALPHA" ;;
    b) select_channel "BETA" ;;
    *) echo "Error: Invalid argument: -$OPTARG" && usage ;;
  esac
done
shift $((OPTIND - 1))

# Check if jq is installed
if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is not installed"
  exit 1
fi

# Check if the server is running
if screen -ls | grep -qF "minecraft-server"; then
  echo "Error: Server is running"
  exit 1
fi

echo "Checking for update..."

# Determine target version
if [[ $# -eq 0 ]]; then
  versions=$(curl -s -H "User-Agent: $USER_AGENT" "$PAPER_API" | \
    jq -r '.versions | to_entries[] | .value[]' | \
    sort -V -r)

  for version in $versions; do
    builds=$(get_builds "$version")
    download_url=$(get_download_url "$builds")

    if [[ "$download_url" != "null" ]]; then
      new_version="$version"
      new_build=$(get_build "$builds")
      break
    fi
  done
else
  new_version="$1"

  builds=$(get_builds "$1")
  if echo "$builds" | jq -e '.ok == false' > /dev/null 2>&1; then
    error_msg=$(echo "$builds" | jq -r '.message // "Unknown error"')
    echo "Error: $error_msg"
    usage
  fi

  new_build=$(get_build "$builds")
  download_url=$(get_download_url "$builds")

  if [[ "$download_url" == "null" ]]; then
    echo "Error: No ${channel,,} build for version $1"
    exit 1
  fi
fi

# Read current installed version from version_history.json
current_version="N/A"
current_build="N/A"
if [[ -f "$VERSION_FILE" ]]; then
  version_info=$(jq -r '.currentVersion // ""' "$VERSION_FILE")
  if [[ -n "$version_info" ]]; then
    current_version=$(echo "$version_info" | cut -d '-' -f1)
    current_build=$(echo "$version_info" | cut -d '-' -f2)
  fi
fi

# Display current and new version info
echo
echo "Current version: $current_version (build $current_build)"
echo "New version:     $new_version (build $new_build) [${channel,,}]"
echo

# Check if already up to date
if [[ "$current_version" == "$new_version" && "$current_build" == "$new_build" ]]; then
  echo "You are running the latest ${channel,,} build"
  exit 0
fi

# Confirmation prompt
read -rp "Update to $new_version (build $new_build)? [y/N]: " confirm
if [[ "$confirm" =~ ^[Yy]$ ]]; then
  printf "Downloading server jar... "
  curl -s -H "User-Agent: $USER_AGENT" "$download_url" -o "$SERVER_JAR"
  echo "done!"
else
  echo "Update cancelled"
fi
